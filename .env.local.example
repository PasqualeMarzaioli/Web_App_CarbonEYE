# sito/.env.local.example - Vercel production environment variables for CarbonEYE.
# Use `vercel env pull` to write real values into the gitignored sito/.env.local file.
# Author: Pasquale Marzaioli

# Runtime
PUBLIC_URL=https://your-app.vercel.app
APP_BASE_URL=https://your-app.vercel.app
LOG_LEVEL=info

# Auth and shared secrets
ADMIN_EMAILS=admin@example.com
SESSION_SECRET=replace-with-openssl-rand-hex-32
CARBONEYE_PIPELINE_API_KEY=replace-with-api-key-created-by-api-ts-admin-endpoint
MONITORING_API_KEY=replace-with-openssl-rand-hex-32
MONITORING_RATE_LIMIT_RPM=60
AUTH_RATE_LIMIT_MAX=20
CRON_SECRET=replace-with-openssl-rand-hex-32

# Database
DATABASE_URL=postgres://carboneyeadmin:password@carboneye-postgres.postgres.database.azure.com:5432/carboneye?sslmode=require

# Azure services used by the Vercel app
AZURE_COSMOS_CONNECTION_STRING=AccountEndpoint=https://<cosmos-account>.documents.azure.com:443/;AccountKey=<cosmos-key>;
AZURE_COSMOS_DATABASE=carboneye
AZURE_COSMOS_CONTAINER=certificates
AZURE_FUNCTIONS_URL=https://<node-function-app>.azurewebsites.net
AZURE_FUNCTIONS_KEY=<node-function-host-key>
AZURE_ANALYZE_TIMEOUT_MS=120000

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Email
RESEND_API_KEY=re_xxx
EMAIL_FROM=CarbonEYE <noreply@example.com>
